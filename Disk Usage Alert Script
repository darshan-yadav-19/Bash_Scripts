#!/bin/bash
# Checks disk usage against a threshold and mails the team if breached
# Default threshold 80%, override with arg1
# Add to cron, e.g. every 15 min: */15 * * * * /opt/scripts/disk_alert.sh

set -eu

THRESHOLD=${1:-80}
ADMIN_MAIL="admin@example.com"
HOST=$(hostname)
FLAG=0
MSG=""

while read -r FS SIZE USED AVAIL PCT MOUNT; do
    PCT_NUM=${PCT%\%}
    if [ "$PCT_NUM" -ge "$THRESHOLD" ]; then
        FLAG=1
        MSG="$MSG\n$MOUNT ($FS) is at $PCT - check ASAP"
    fi
done < <(df -h | grep -E '^/dev/')

if [ "$FLAG" -eq 1 ]; then
    echo -e "Disk threshold (${THRESHOLD}%) crossed on $HOST:$MSG" | \
        mail -s "Disk Alert - $HOST" "$ADMIN_MAIL"
    echo -e "Alert sent.$MSG"
else
    echo "All good, nothing over ${THRESHOLD}%."
fi
